{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thegreeting.github.io/barnard/schema/barnard/v2/events.schema.json",
  "title": "Barnard Events (v2)",
  "description": "v2 event stream emitted by the Barnard SDK. Byte-valued fields are lowercase hex. TEK is never emitted over BLE and never appears in DetectionEvent.",
  "oneOf": [
    { "$ref": "#/$defs/DetectionEvent" },
    { "$ref": "#/$defs/RssiUpdateEvent" },
    { "$ref": "#/$defs/StateEvent" },
    { "$ref": "#/$defs/ConstraintEvent" },
    { "$ref": "#/$defs/ErrorEvent" },
    { "$ref": "#/$defs/DebugEvent" }
  ],
  "$defs": {
    "DetectionEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "detection" },
        "timestamp": { "$ref": "common.schema.json#/$defs/Timestamp" },
        "transport": { "$ref": "common.schema.json#/$defs/TransportKind" },
        "formatVersion": { "type": "integer", "minimum": 0 },
        "rpid": { "$ref": "common.schema.json#/$defs/RpidHex" },
        "reporterRpid": { "$ref": "common.schema.json#/$defs/RpidHex" },
        "detectedDisplayId": {
          "oneOf": [
            { "$ref": "common.schema.json#/$defs/DisplayIdHex" },
            { "type": "null" }
          ],
          "description": "Nullable: null when B003 read failed; the detection is still emitted."
        },
        "enin": {
          "type": "integer",
          "minimum": 0,
          "description": "ENIN at the observation timestamp (floor(unix_seconds / 600))."
        },
        "rssi": { "type": "integer" },
        "rssiSummary": {
          "oneOf": [
            { "$ref": "#/$defs/RssiSummary" },
            { "type": "null" }
          ]
        },
        "payloadRaw": {
          "oneOf": [
            { "$ref": "common.schema.json#/$defs/RpidHex" },
            { "type": "null" }
          ],
          "description": "Raw 17-byte RPID payload as hex, or null."
        },
        "debugLocalName": {
          "type": ["string", "null"],
          "description": "Debug-only local name observed during scan."
        }
      },
      "required": [
        "type",
        "timestamp",
        "transport",
        "formatVersion",
        "rpid",
        "reporterRpid",
        "detectedDisplayId",
        "enin",
        "rssi"
      ]
    },
    "RssiUpdateEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "rssi_update" },
        "timestamp": { "$ref": "common.schema.json#/$defs/Timestamp" },
        "rpid": { "$ref": "common.schema.json#/$defs/RpidHex" },
        "reporterRpid": {
          "$ref": "common.schema.json#/$defs/RpidHex",
          "description": "The reporter's 17-byte RPID wire form at the observation timestamp; atomic with enin."
        },
        "enin": {
          "type": "integer",
          "description": "ENIN (floor(unix_s / 600)) at the observation timestamp; atomic with reporterRpid."
        },
        "rssi": { "type": "integer" },
        "detectedDisplayId": {
          "oneOf": [
            { "$ref": "common.schema.json#/$defs/DisplayIdHex" },
            { "type": "null" }
          ],
          "description": "Cached from a prior GATT exchange; null or omitted when not yet known."
        }
      },
      "required": ["type", "timestamp", "rpid", "reporterRpid", "enin", "rssi"]
    },
    "RssiSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "min": { "type": "integer" },
        "max": { "type": "integer" },
        "mean": { "type": "number" }
      },
      "required": ["count", "min", "max", "mean"]
    },
    "StateEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "state" },
        "timestamp": { "$ref": "common.schema.json#/$defs/Timestamp" },
        "state": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "isScanning": { "type": "boolean" },
            "isAdvertising": { "type": "boolean" },
            "eventCode": { "type": ["string", "null"] }
          },
          "required": ["isScanning", "isAdvertising"]
        },
        "reasonCode": { "type": ["string", "null"] }
      },
      "required": ["type", "timestamp", "state"]
    },
    "ConstraintEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "constraint" },
        "timestamp": { "$ref": "common.schema.json#/$defs/Timestamp" },
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": ["string", "null"] },
        "requiredAction": { "type": ["string", "null"] }
      },
      "required": ["type", "timestamp", "code"]
    },
    "ErrorEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "error" },
        "timestamp": { "$ref": "common.schema.json#/$defs/Timestamp" },
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "recoverable": { "type": ["boolean", "null"] }
      },
      "required": ["type", "timestamp", "code", "message"]
    },
    "DebugEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "debug" },
        "timestamp": { "$ref": "common.schema.json#/$defs/Timestamp" },
        "level": { "$ref": "common.schema.json#/$defs/DebugLevel" },
        "name": { "type": "string", "minLength": 1 },
        "data": { "type": ["object", "null"], "additionalProperties": true }
      },
      "required": ["type", "timestamp", "level", "name"]
    }
  }
}
